# Code-Puppy Workspace Monorepo

# ═══════════════════════════════════════════════════════════
# USER PROJECTS (Private - Never Share These!)
# ═══════════════════════════════════════════════════════════

# User's private projects - each user has their own
P*/
projects/*/
!projects/project-alpha/  # Example project only

# User-specific data directories
memory/
shared-agents/
shared-rules/
skills/

# POPPY user data (local to each installation)
admin/data/*
!admin/data/.gitkeep
admin/.poppy/

# User directories (keep structure with .gitkeep)
projects/*
!projects/.gitkeep
agents/*
!agents/.gitkeep
skills/*
!skills/.gitkeep
prompts/*
!prompts/.gitkeep

# ═══════════════════════════════════════════════════════════
# SECRETS & KEYS (Critical - Never Commit!)
# ═══════════════════════════════════════════════════════════

# API Keys and tokens
*.key
*.pem
*.cert
*.secret
.env
.env.*
!.env.example

# Config files with secrets
admin/data/git-config.json
**/config.json
!admin/lib/config.js
!admin/package.json

# ═══════════════════════════════════════════════════════════
# DEPENDENCIES
# ═══════════════════════════════════════════════════════════

node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ═══════════════════════════════════════════════════════════
# BUILD OUTPUTS
# ═══════════════════════════════════════════════════════════

dist/
build/
.expo/
web-build/
*.tgz
out/
.next/
.nuxt/

# ═══════════════════════════════════════════════════════════
# TEMPORARY & CACHE
# ═══════════════════════════════════════════════════════════

*.tmp
*.temp
.cache/
.temp/
admin/data/git-temp/

# ═══════════════════════════════════════════════════════════
# OS FILES
# ═══════════════════════════════════════════════════════════

.DS_Store
Thumbs.db
desktop.ini

# ═══════════════════════════════════════════════════════════
# IDE & EDITORS
# ═══════════════════════════════════════════════════════════

.vscode/
.idea/
*.swp
*.swo
*~

# ═══════════════════════════════════════════════════════════
# TESTING
# ═══════════════════════════════════════════════════════════

coverage/
.nyc_output/
*.lcov

# ═══════════════════════════════════════════════════════════
# WHAT WE KEEP (Public Template)
# ═══════════════════════════════════════════════════════════

# Keep these tracked in the template:
# - admin/ (core POPPY system)
# - agents/ (example agents for marketplace)
# - templates/ (project templates)
# - docs/ (documentation)
# - README, LICENSE, etc.

USER-CONFIG.md  
.env 
.creator  
global-analytics.json 
